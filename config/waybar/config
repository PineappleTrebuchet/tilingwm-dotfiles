        }, 
    },

    "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "ο¹°",
        "deactivated": "ο¹Α"
        }
    },

    "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "interval": 600,
        "exec": "$HOME/.config/waybar/scripts/weather.py",
        "return-type": "json",
        "on-click": "gnome-weather"
