        "format-disconnected": "σΑ•Σ  Down",
        "tooltip-disconnected": false,
        "family": "ipv4",
        "interval": 3,
        "on-click": "nm-connection-editor;"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["β‰Ψ", "β‰ΦοΗé", "β‰ÄοΗé", "σΑ•® "],
        "interval": 60
    },

    "cpu": {
        "format": "ο£Φ  {usage}%", 
        "interval": 3
    },

    "memory": {
        "format": "{used}GiB",
        "tooltip-format": "{percentage}% used",
        "interval": 3
    },

    "temperature": {
	    "thermal-zone": 0,
	    "format": "{icon} {temperatureC}¬ΑC",
	    "format-icons":["ο΄â"],
