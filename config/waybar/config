        "tooltip-format": "Profile: {profile}\nDriver: {driver}",
        "format-icons": {       
            "default": "bal",
            "performance": "per",
            "balanced:": "bal",
            "power-saver": "sav"
        }
    },

    "network": {
        "format-wifi": "σΑ•©  WiFi",
