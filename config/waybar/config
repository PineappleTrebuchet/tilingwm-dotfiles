{
    "layer": "top",	
    "position": "top",
    "height": 28,
    "modules-left": [
        // "idle_inhibitor",
        "sway/workspaces",
        "niri/workspaces",
        "tray",
        "sway/scratchpad",
        "sway/window",
        "niri/window",
        "sway/mode",
    ],

    "modules-center": ["clock#date", "clock#time"],
    "modules-right": [
        "custom/audio_idle_inhibitor",
        "power-profiles-daemon",
        //"memory", 
        "network",
        "custom/weather",
        // "cpu", 
        // "temperature", 
        "backlight",
        "pulseaudio",
        "battery",
    ],	

    "workspaces": {
        "disable-scroll": true,
        "disable-markup": true,
        "format": "{index}",
    },

    "sway/scratchpad": {
        "format": "οÄ° {count}",
        "on-click": "swaymsg scratchpad show"
    },

    "sway/window": {
        "format": "{}",
        "tooltip": false,
        "max-length": 50
    },

    "tray": {
        "icon-size": 22, 
        "spacing": 6
    },

    "clock#date": {
        "format": "ο¹≥ {:%a %m/%d}",
        "interval": 1,
        "tooltip": false
    },

    "clock#time": {
        "format": "σΑΞî  {:%I:%M %p}",
